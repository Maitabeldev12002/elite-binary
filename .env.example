# ═══════════════════════════════════════════════════════════════════════════
# ELITE BINARY - PRODUCTION ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════

# ─ SERVER ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─ SECURITY ────────────────────────────────────────────────────────────────
JWT_SECRET=your-secure-random-jwt-secret-change-this-in-production
ADMIN_KEY=your-secure-admin-key-change-this-in-production

# ─ DATABASE ────────────────────────────────────────────────────────────────
# File-based database (default)
USE_FILE_DB=true
DB_DIR=/tmp

# Supabase PostgreSQL (optional - takes precedence over file DB)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_TABLE=app_state
SUPABASE_DB_ID=elite-binary

# ─ PAYMENT PROVIDER ────────────────────────────────────────────────────────
# Choose: payhero OR mpesa
PAYMENT_PROVIDER=payhero

# PayHero Configuration (M-Pesa via PayHero)
PAYHERO_HOST=backend.payhero.co.ke
PAYHERO_BASIC_AUTH=your-base64-encoded-payhero-credentials
PAYHERO_CHANNEL_ID=8005
PAYHERO_PROVIDER=m-pesa
PAYHERO_CALLBACK_URL=https://binaryelite.online/api/payhero/callback

# Direct M-Pesa Configuration (STK Push)
MPESA_ENV=sandbox
MPESA_BASIC_AUTH=your-base64-mpesa-credentials
MPESA_CONSUMER_KEY=your-mpesa-consumer-key
MPESA_CONSUMER_SECRET=your-mpesa-consumer-secret
MPESA_SHORTCODE=174379
MPESA_CHANNEL_ID=174379
MPESA_PASSKEY=your-mpesa-passkey
MPESA_CALLBACK_URL=https://binaryelite.online/api/mpesa/stk-callback

# M-Pesa B2C (Withdrawals)
MPESA_B2C_SHORTCODE=600984
MPESA_B2C_INITIATOR_NAME=EliteBinary
MPESA_B2C_SECURITY_CREDENTIAL=your-encrypted-b2c-credential
MPESA_B2C_RESULT_URL=https://binaryelite.online/api/mpesa/b2c-result
MPESA_B2C_TIMEOUT_URL=https://binaryelite.online/api/mpesa/b2c-result

# ─ PAYMENT TESTING ─────────────────────────────────────────────────────────
# Set to false for live payments, true for mock/testing
MOCK_PAYMENTS=true

# ─ TRADING ENGINE CONFIGURATION ────────────────────────────────────────────
# Default payout rate (multiplier) - 0.8 = 80% payout
DEFAULT_PAYOUT_RATE=0.952

# Win probability for AI settlement (0.0 - 0.99)
DEFAULT_WIN_PROBABILITY=0.5

# Settlement delay in milliseconds
SETTLEMENT_DELAY_MS=900

# Designated deposit wallet (display to users)
DESIGNATED_WALLET=I & M Bank Limited 06509279966150 / Channel ID 8005

# ─ AUTO TRADING SETTINGS ───────────────────────────────────────────────────
# Default auto trading behavior
AUTO_TRADING_ENABLED=true
AUTO_TRADING_MAX_DURATION_MS=3600000
AUTO_TRADING_MIN_INTERVAL_MS=2000
AUTO_TRADING_MAX_INTERVAL_MS=10000

# ─ LOGGING & MONITORING ───────────────────────────────────────────────────
LOG_LEVEL=info
DEBUG_MODE=false

# Optional: Sentry error tracking
SENTRY_DSN=

# ═══════════════════════════════════════════════════════════════════════════
